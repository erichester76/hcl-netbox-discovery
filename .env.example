# hcl-netbox-discovery – environment variable reference
# Copy this file to .env and fill in your credentials.
# The .env file is listed in .gitignore and should NEVER be committed.

# ---------------------------------------------------------------------------
# Web UI  (web_server.py / docker-compose web service)
# ---------------------------------------------------------------------------
# TCP port the web UI listens on (default: 5000)
WEB_PORT=5000
# Bind address for the web UI (default: 0.0.0.0)
WEB_HOST=0.0.0.0
# Secret key for Flask sessions – change this in production!
WEB_SECRET_KEY=change-me-in-production
# Path for the SQLite job-tracking database (default: ./collector_jobs.sqlite3)
COLLECTOR_DB_PATH=
# Set to "true" to enable Flask debug mode (never use in production)
FLASK_DEBUG=false

# ---------------------------------------------------------------------------
# NetBox (required by every mapping)
# ---------------------------------------------------------------------------
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=your_netbox_api_token

# Optional caching: none | redis | sqlite
NETBOX_CACHE_BACKEND=none
# Redis:  NETBOX_CACHE_URL=redis://redis:6379/0
# SQLite: NETBOX_CACHE_URL=/tmp/netbox_cache.db
NETBOX_CACHE_URL=
# Cache entry TTL in seconds (default: 300)
NETBOX_CACHE_TTL=300
# Cache key prefix used to namespace keys in redis/sqlite backends (default: nbx:)
NETBOX_CACHE_KEY_PREFIX=nbx:
# Prewarm sentinel TTL in seconds; leave empty to use cache TTL (default: unset)
NETBOX_PREWARM_SENTINEL_TTL=
# Number of consecutive Redis failures before the cache is auto-disabled for the run (default: 5)
NETBOX_CACHE_DISABLE_ON_FAILURES=5

# API rate limiting
# Maximum requests per second sent to NetBox; 0 = unlimited (default: 0)
NETBOX_RATE_LIMIT=0
# Token-bucket burst size for rate limiting (default: 1)
NETBOX_RATE_LIMIT_BURST=1

# API retry behaviour
# Number of retry attempts on transient failures (default: 3)
NETBOX_RETRY_ATTEMPTS=3
# Initial delay in seconds before the first retry (default: 0.3)
NETBOX_RETRY_INITIAL_DELAY=0.3
# Exponential back-off multiplier applied between retries (default: 2.0)
NETBOX_RETRY_BACKOFF_FACTOR=2.0
# Maximum delay in seconds between retries (default: 15.0)
NETBOX_RETRY_MAX_DELAY=15.0
# Maximum random jitter in seconds added to each retry delay (default: 0.0)
NETBOX_RETRY_JITTER=0.0
# Comma-separated 4xx HTTP status codes that trigger a retry (default: 408,409,425,429)
NETBOX_RETRY_ON_4XX=408,409,425,429

# NetBox branch name for branch-aware NetBox deployments; leave empty for default branch
NETBOX_BRANCH=

# ---------------------------------------------------------------------------
# NetBox Source  (mappings/netbox-to-netbox.hcl.example)
# ---------------------------------------------------------------------------
# URL of the source NetBox instance to read objects from
SOURCE_NETBOX_URL=
# API token for the source NetBox instance
SOURCE_NETBOX_TOKEN=
# Set to "false" to disable SSL verification for the source NetBox (default: true)
SOURCE_NETBOX_VERIFY_SSL=true
# Optional JSON filter dict passed to the source collection, e.g. {"site": "lon01"}
SOURCE_NETBOX_FILTERS=

# ---------------------------------------------------------------------------
# General collector flags
# ---------------------------------------------------------------------------
# Set to "true" to log payloads without writing anything to NetBox
DRY_RUN=false

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# VMware vCenter  (mappings/vmware.hcl.example)
# ---------------------------------------------------------------------------
VCENTER_URL=vcenter.example.com
VCENTER_USER=administrator@vsphere.local
VCENTER_PASS=changeme

# ---------------------------------------------------------------------------
# Cisco Catalyst Center / DNA Center  (mappings/catc.hcl.example)
# ---------------------------------------------------------------------------
CATC_HOST=https://catc.example.com
CATC_USER=admin
CATC_PASS=changeme
CATC_VERIFY_SSL=true

# ---------------------------------------------------------------------------
# Lenovo XClarity  (mappings/xclarity.hcl.example, mappings/xclarity-modules.hcl.example)
# ---------------------------------------------------------------------------
# XCLARITY_HOST can be just a hostname/IP or a full URL; HTTPS port 443 is
# always used unless an explicit port is included in the URL.
#   e.g.  XCLARITY_HOST=xclarity.example.com
#   e.g.  XCLARITY_HOST=https://xclarity.example.com
#   e.g.  XCLARITY_HOST=https://xclarity.example.com:8443
XCLARITY_HOST=https://xclarity.example.com
XCLARITY_USER=admin
XCLARITY_PASS=changeme
XCLARITY_VERIFY_SSL=true

# ---------------------------------------------------------------------------
# Microsoft Azure  (mappings/azure.hcl.example)
# ---------------------------------------------------------------------------
# Use "service_principal" + client_id/secret, or "default" for
# DefaultAzureCredential (az login, managed identity, etc.)
AZURE_AUTH_METHOD=default
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Comma-separated subscription IDs to limit scope (leave empty for all)
AZURE_SUBSCRIPTION_IDS=

# ---------------------------------------------------------------------------
# LDAP  (mappings/ldap.hcl.example)
# ---------------------------------------------------------------------------
LDAP_SERVER=ldaps://ldap.example.com:636
LDAP_USER=cn=service-account,dc=example,dc=com
LDAP_PASS=changeme
LDAP_SEARCH_BASE=dc=example,dc=com
LDAP_FILTER=(objectClass=person)

# ---------------------------------------------------------------------------
# LDAP / Novell eDirectory JNSU schema  (mappings/jnsu.hcl.example)
# ---------------------------------------------------------------------------
# Uses the same LDAP_SERVER / LDAP_USER / LDAP_PASS credentials above.
LDAP_FILTER=(DirXMLjnsuDHCPAddress=*)
LDAP_PREFIX_LENGTH=
LDAP_SKIP_APS=true

# ---------------------------------------------------------------------------
# Active Directory  (mappings/active-directory-computers.hcl.example)
# ---------------------------------------------------------------------------
AD_SERVER=ldaps://dc01.corp.example.com
AD_USER=CN=svc-netbox,OU=ServiceAccounts,DC=corp,DC=example,DC=com
AD_PASS=changeme
# Search base for computer objects
AD_SEARCH_BASE=OU=Computers,DC=corp,DC=example,DC=com
AD_DOMAIN=corp.example.com
# Optional: override default search filters
# AD_COMPUTERS_FILTER=(objectClass=computer)
# AD_USERS_FILTER=(&(objectClass=user)(objectCategory=person)(!(objectClass=computer))(!(userAccountControl:1.2.840.113556.1.4.803:=2)))

# ---------------------------------------------------------------------------
# Cisco Nexus Dashboard Fabric Controller (NDFC)  (mappings/nexus.hcl.example)
# ---------------------------------------------------------------------------
NDFC_HOST=ndfc.example.com
NDFC_USER=admin
NDFC_PASS=changeme
NDFC_VERIFY_SSL=true
# Set to "true" to fetch per-switch interface lists from NDFC
NDFC_FETCH_INTERFACES=false

# ---------------------------------------------------------------------------
# F5 BIG-IP  (mappings/f5.hcl.example)
# ---------------------------------------------------------------------------
F5_HOST=f5.example.com
F5_USER=admin
F5_PASS=changeme
F5_VERIFY_SSL=true
# Set to "true" to fetch physical interfaces and self-IPs
F5_FETCH_INTERFACES=false
# NetBox site name to assign the BIG-IP appliance to
F5_SITE=Default

# ---------------------------------------------------------------------------
# Prometheus node-exporter  (mappings/prometheus.hcl.example)
# ---------------------------------------------------------------------------
PROMETHEUS_URL=http://prometheus.example.com:9090
PROMETHEUS_USER=
PROMETHEUS_PASS=
PROMETHEUS_VERIFY_SSL=true
# Set to "true" to fetch per-node network interface info
PROMETHEUS_FETCH_INTERFACES=true

# ---------------------------------------------------------------------------
# SNMP  (mappings/juniper-snmp.hcl.example, mappings/linux-snmp.hcl.example)
# ---------------------------------------------------------------------------
# Comma-separated list of hostnames or IP addresses to poll
SNMP_HOSTS=router1.example.com,router2.example.com
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_PORT=161
SNMP_TIMEOUT=5
SNMP_RETRIES=1

# SNMPv3 (only required when SNMP_VERSION=3)
SNMP_V3_USER=
SNMP_V3_AUTH_PASS=
SNMP_V3_AUTH_PROTO=sha
SNMP_V3_PRIV_PASS=
SNMP_V3_PRIV_PROTO=aes

# Linux SNMP specific (mappings/linux-snmp.hcl.example)
LINUX_SITE=Default

# ---------------------------------------------------------------------------
# Per-source sync flags
# ---------------------------------------------------------------------------
COLLECTOR_SYNC_INTERFACES=true
COLLECTOR_SYNC_INVENTORY=true
COLLECTOR_SYNC_DISKS=true

# ---------------------------------------------------------------------------
# Tenable One / Nessus  (mappings/tenable.hcl.example)
# ---------------------------------------------------------------------------
# For Tenable.io / Tenable One: leave TENABLE_HOST empty (defaults to cloud.tenable.com)
# For on-prem Nessus: set TENABLE_HOST to e.g. https://nessus.example.com:8834
TENABLE_HOST=
TENABLE_ACCESS_KEY=
TENABLE_SECRET_KEY=
# "tenable" (default) or "nessus"
TENABLE_PLATFORM=tenable
# Days to look back for asset/vulnerability activity
TENABLE_DATE_RANGE=30
TENABLE_VERIFY_SSL=true
# Set to "true" to enable the "findings" collection
TENABLE_INCLUDE_ASSET_DETAILS=false
