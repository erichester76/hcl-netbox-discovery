# =============================================================================
# clemson-netbox-discovery – Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in values for the source types you use.
# Variables marked REQUIRED must be set; optional variables show their defaults.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your values
#   source .env  (or use a tool like direnv / python-dotenv)
#   python main.py --mapping mappings/<source>.hcl
# =============================================================================


# -----------------------------------------------------------------------------
# NetBox (REQUIRED by all source types)
# -----------------------------------------------------------------------------

# Full base URL of your NetBox instance (no trailing slash).
NETBOX_URL=https://netbox.example.com

# NetBox API token with read/write access.
NETBOX_TOKEN=0123456789abcdef0123456789abcdef0123456789abcdef

# Caching backend used by the NetBox client.
# Options: none | redis | sqlite
# Default: none
NETBOX_CACHE_BACKEND=none

# Connection URL for the chosen cache backend.
#   Redis  → redis://localhost:6379/0
#   SQLite → .nbx_cache.sqlite3
# Leave empty when NETBOX_CACHE_BACKEND=none.
NETBOX_CACHE_URL=

# Number of consecutive Redis failures before the cache is automatically
# disabled for the remainder of the run.
# Default: 5
NETBOX_CACHE_DISABLE_ON_FAILURES=5


# -----------------------------------------------------------------------------
# Collector Options (apply to all source types)
# -----------------------------------------------------------------------------

# Run in dry-run mode: log what would be written to NetBox without actually
# making any changes.
# Default: false
DRY_RUN=false

# Sync network interface objects to NetBox.
# Default: true
COLLECTOR_SYNC_INTERFACES=true

# Sync disk inventory items to NetBox.
# Default: true
COLLECTOR_SYNC_DISKS=true

# Sync general inventory items to NetBox.
# Default: true
COLLECTOR_SYNC_INVENTORY=true


# -----------------------------------------------------------------------------
# VMware vCenter  (mappings/vmware.hcl)
# -----------------------------------------------------------------------------
# Collects: clusters, hosts, virtual machines

# Hostname or IP address of the vCenter server (no https:// prefix).
# REQUIRED for VMware source.
VCENTER_URL=vcenter.example.com

# vCenter username with read access to the desired data center.
# REQUIRED for VMware source.
VCENTER_USER=admin@vsphere.local

# vCenter password.
# REQUIRED for VMware source.
VCENTER_PASS=changeme


# -----------------------------------------------------------------------------
# Microsoft Azure  (mappings/azure.hcl)
# -----------------------------------------------------------------------------
# Collects: virtual machines, IP prefixes, subscriptions

# Authentication method.
# Options:
#   default           – uses DefaultAzureCredential (az login, managed identity,
#                       environment credentials, etc.)
#   service_principal – uses an explicit tenant/client/secret below
# Default: default
AZURE_AUTH_METHOD=default

# Azure AD tenant ID.
# REQUIRED when AZURE_AUTH_METHOD=service_principal.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Service principal (app registration) client ID.
# REQUIRED when AZURE_AUTH_METHOD=service_principal.
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Service principal client secret.
# REQUIRED when AZURE_AUTH_METHOD=service_principal.
AZURE_CLIENT_SECRET=changeme


# -----------------------------------------------------------------------------
# LDAP / Active Directory  (mappings/ldap.hcl)
# -----------------------------------------------------------------------------
# Collects: DHCP leases (IP address reservations)

# LDAP server URI, including scheme and port if non-standard.
# REQUIRED for LDAP source.
LDAP_SERVER=ldaps://ldap.example.com

# Bind DN used to authenticate to the LDAP server.
# REQUIRED for LDAP source.
LDAP_USER=cn=service-account,ou=ServiceAccounts,dc=example,dc=com

# Bind password for the LDAP bind DN.
# REQUIRED for LDAP source.
LDAP_PASS=changeme

# Base DN from which the DHCP lease search will start.
# REQUIRED for LDAP source.
LDAP_SEARCH_BASE=ou=Network Devices,o=example

# LDAP search filter applied when querying DHCP leases.
# Default: (DirXMLjnsuDHCPAddress=*)
LDAP_FILTER=(DirXMLjnsuDHCPAddress=*)

# Skip entries that look like wireless access points.
# Default: true
LDAP_SKIP_APS=true

# Default subnet prefix length (CIDR notation number only) to append to IP
# addresses that have no mask in the LDAP record.  Leave empty to omit.
# Example: 24  → addresses become x.x.x.x/24
LDAP_PREFIX_LENGTH=


# -----------------------------------------------------------------------------
# Cisco Catalyst Center (CATC)  (mappings/catc.hcl)
# -----------------------------------------------------------------------------
# Collects: network devices

# Hostname or IP address of the Catalyst Center controller (no https:// prefix).
# REQUIRED for CATC source.
CATC_HOST=catalyst.example.com

# Catalyst Center administrator username.
# REQUIRED for CATC source.
CATC_USER=admin

# Catalyst Center administrator password.
# REQUIRED for CATC source.
CATC_PASS=changeme

# Verify the Catalyst Center TLS certificate.
# Set to false only in lab/dev environments with self-signed certificates.
# Default: true
CATC_VERIFY_SSL=true


# -----------------------------------------------------------------------------
# Lenovo XClarity / Generic REST  (mappings/xclarity.hcl)
# -----------------------------------------------------------------------------
# The generic REST adapter uses variables that you define in your HCL mapping
# file via env() calls.  The variables below are the ones referenced by the
# bundled xclarity.hcl example; define equivalent variables for any other
# REST-based source.

# Hostname or IP address of the XClarity controller (no https:// prefix).
# REQUIRED for XClarity source.
XCLARITY_HOST=xclarity.example.com

# XClarity username.
# REQUIRED for XClarity source.
XCLARITY_USER=admin

# XClarity password.
# REQUIRED for XClarity source.
XCLARITY_PASS=changeme

# Verify the XClarity TLS certificate.
# Default: true
XCLARITY_VERIFY_SSL=true
