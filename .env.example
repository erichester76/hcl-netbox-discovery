# hcl-netbox-discovery – startup environment reference
# Copy this file to .env if you need to override startup/bootstrap settings.
# The .env file is listed in .gitignore and should NEVER be committed.
#
# Runtime collector and source configuration is DB-backed and intentionally not
# read from the process environment after startup. Configure NetBox/source
# credentials, cache/retry settings, and source-specific options through the
# web Settings UI or by writing to the SQLite config_settings table.

# ---------------------------------------------------------------------------
# Startup / bootstrap settings
# ---------------------------------------------------------------------------

# TCP port the web UI listens on (default: 5000)
WEB_PORT=5000

# Bind address for the web UI (default: 0.0.0.0)
WEB_HOST=0.0.0.0

# Secret key for Flask sessions – change this in production!
WEB_SECRET_KEY=change-me-in-production

# Path for the SQLite job-tracking database (default: ./collector_jobs.sqlite3)
COLLECTOR_DB_PATH=

# Set to "true" to enable Flask debug mode (never use in production)
FLASK_DEBUG=false

# Logging verbosity for the process startup path: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
