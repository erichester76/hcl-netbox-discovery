# Cisco Catalyst Center → NetBox collector mapping
#
# Required environment variables:
#   CATC_HOST         Catalyst Center hostname or IP (no https://)
#   CATC_USER         Catalyst Center username
#   CATC_PASS         Catalyst Center password
#   NETBOX_URL        NetBox base URL
#   NETBOX_TOKEN      NetBox API token
#
# Optional:
#   CATC_VERIFY_SSL           true | false  (default: true)
#   CATC_FETCH_INTERFACES     true | false  (default: true)
#                             When true, interfaces are fetched per-device and
#                             embedded in each device record so that the
#                             interface {} block below can sync them to NetBox.
#   CATC_FETCH_MODULES        true | false  (default: false)
#                             When true, device module inventory is fetched and
#                             embedded so the module {} blocks below can sync it.
#   CATC_SITE_ASSIGNMENT_STRATEGY auto | bulk | membership  (default: auto)
#                             Choose which device/site join method runs first.
#                             The adapter still falls back to the other method.
#   CATC_WAIT_ON_RATE_LIMIT   true | false  (default: true)
#                             Let dnacentersdk honor Retry-After responses from
#                             Catalyst Center automatically.
#   CATC_RATE_LIMIT_RETRY_ATTEMPTS      integer (default: 3)
#   CATC_RATE_LIMIT_RETRY_INITIAL_DELAY seconds (default: 1.0)
#   CATC_RATE_LIMIT_RETRY_MAX_DELAY     seconds (default: 30.0)
#   CATC_RATE_LIMIT_RETRY_JITTER        seconds (default: 0.5)
#   NETBOX_CACHE_BACKEND      Cache backend: none | redis | sqlite  (default: none)
#   NETBOX_CACHE_URL          Redis URL or SQLite path
#   DRY_RUN                   Set to "true" to log payloads without writing
#   COLLECTOR_SYNC_INTERFACES true | false  (default: true)
#   COLLECTOR_SYNC_INVENTORY  true | false  (default: true)
#   COLLECTOR_SYNC_MODULES    true | false  (default: true)

source "catc" {
  api_type          = "catc"
  url               = "env('CATC_HOST')"
  username          = "env('CATC_USER')"
  password          = "env('CATC_PASS')"
  verify_ssl        = "env('CATC_VERIFY_SSL', 'true')"
  fetch_interfaces  = "env('CATC_FETCH_INTERFACES', 'true')"
  fetch_modules     = "env('CATC_FETCH_MODULES', 'false')"
  site_assignment_strategy = "env('CATC_SITE_ASSIGNMENT_STRATEGY', 'auto')"
  wait_on_rate_limit         = "env('CATC_WAIT_ON_RATE_LIMIT', 'true')"
  rate_limit_retry_attempts  = "env('CATC_RATE_LIMIT_RETRY_ATTEMPTS', '3')"
  rate_limit_retry_initial_delay = "env('CATC_RATE_LIMIT_RETRY_INITIAL_DELAY', '1.0')"
  rate_limit_retry_max_delay = "env('CATC_RATE_LIMIT_RETRY_MAX_DELAY', '30.0')"
  rate_limit_retry_jitter    = "env('CATC_RATE_LIMIT_RETRY_JITTER', '0.5')"
}

netbox {
  url        = "env('NETBOX_URL')"
  token      = "env('NETBOX_TOKEN')"
  cache      = "env('NETBOX_CACHE_BACKEND', 'none')"
  cache_url  = "env('NETBOX_CACHE_URL', '')"
  rate_limit = "env('NETBOX_RATE_LIMIT', '0')"
}

collector {
  max_workers      = 4
  dry_run          = "env('DRY_RUN', 'false')"
  sync_tag         = "catc-sync"
  regex_dir        = "./regex"
  sync_interfaces  = "env('COLLECTOR_SYNC_INTERFACES', 'true')"
  sync_inventory   = "env('COLLECTOR_SYNC_INVENTORY', 'true')"
  sync_modules     = "env('COLLECTOR_SYNC_MODULES', 'true')"
}

object "device" {
  source_collection = "devices"
  netbox_resource   = "dcim.devices"
  lookup_by         = ["name", "site"]
  max_workers       = 4

  prerequisite "manufacturer" {
    method   = "ensure_manufacturer"
    args     = { name = "source('manufacturer')" }
    optional = false
  }

  prerequisite "device_type" {
    method   = "ensure_device_type"
    args     = {
      model        = "when(source('model'), source('model'), 'Unknown')"
      manufacturer = "prereq('manufacturer')"
    }
    optional = false
  }

  prerequisite "role" {
    method   = "ensure_device_role"
    args     = { name = "when(source('role'), source('role'), 'Network Device')" }
    optional = false
  }

  prerequisite "site" {
    method   = "ensure_site"
    args     = { name = "when(source('site_name'), regex_file(source('site_name'), 'catc_site_to_site'), 'Unknown')" }
    optional = false
  }

  prerequisite "location" {
    method   = "ensure_location"
    args     = {
      name = "when(source('location_name'), source('location_name'), None)"
      site = "prereq('site')"
    }
    optional = true
  }

  prerequisite "platform" {
    method   = "ensure_platform"
    args     = {
      name         = "when(source('platform_name'), source('platform_name'), 'Unknown')"
      manufacturer = "prereq('manufacturer')"
    }
    optional = true
  }

  field "name" {
    value = "when(source('name'), source('name'), 'Unknown')"
  }

  field "device_type" {
    value = "prereq('device_type')"
  }

  field "role" {
    value = "prereq('role')"
  }

  field "site" {
    value = "prereq('site')"
  }

  field "location" {
    value = "prereq('location')"
  }

  field "platform" {
    value = "prereq('platform')"
  }

  field "serial" {
    value = "source('serial') or None"
  }

  field "status" {
    value = "source('status')"
  }

  field "primary_ip4" {
    value = "when(source('ip_address') != '', source('ip_address'), None)"
  }

  field "tags" {
    type  = "tags"
    value = "['catc-sync']"
  }

  interface {
    source_items = "interfaces"
    enabled_if   = "collector.sync_interfaces"

    field "name" {
      value = "source('name')"
    }

    field "type" {
      value = "when(source('type'), source('type'), 'other')"
    }

    field "enabled" {
      value = "source('enabled')"
    }

    field "description" {
      value = "when(source('description'), source('description'), '')"
    }

    field "mgmt_only" {
      value = "source('mgmt_only')"
    }

    field "mac_address" {
      value = "when(source('mac_address') != '', source('mac_address'), None)"
    }

    ip_address {
      source_items = "when(source('ip_address') != '', [{'address': source('ip_address')}], [])"
      primary_if   = "first"

      field "address" {
        value = "source('address')"
      }

      field "status" {
        value = "'active'"
      }
    }
  }

  module {
    source_items = "[m for m in (source('modules') or []) if m.get('profile') == 'Power supply']"
    profile      = "Power supply"
    enabled_if   = "collector.sync_modules"
    dedupe_by    = "source('serial') or source('bay_name')"

    field "bay_name" {
      value = "source('bay_name')"
    }

    field "position" {
      value = "source('position')"
    }

    field "model" {
      value = "source('model')"
    }

    field "serial" {
      value = "source('serial')"
    }

    field "manufacturer" {
      value = "source('manufacturer')"
    }

    field "description" {
      value = "source('description')"
    }

    field "status" {
      value = "source('status')"
    }

    attribute "part_number" {
      value = "source('attributes.part_number')"
    }
  }

  module {
    source_items = "[m for m in (source('modules') or []) if m.get('profile') == 'Fan']"
    profile      = "Fan"
    enabled_if   = "collector.sync_modules"
    dedupe_by    = "source('serial') or source('bay_name')"

    field "bay_name" {
      value = "source('bay_name')"
    }

    field "position" {
      value = "source('position')"
    }

    field "model" {
      value = "source('model')"
    }

    field "serial" {
      value = "source('serial')"
    }

    field "manufacturer" {
      value = "source('manufacturer')"
    }

    field "description" {
      value = "source('description')"
    }

    field "status" {
      value = "source('status')"
    }
  }

  module {
    source_items = "[m for m in (source('modules') or []) if m.get('profile') == 'Supervisor']"
    profile      = "Supervisor"
    enabled_if   = "collector.sync_modules"
    dedupe_by    = "source('serial') or source('bay_name')"

    field "bay_name" {
      value = "source('bay_name')"
    }

    field "position" {
      value = "source('position')"
    }

    field "model" {
      value = "source('model')"
    }

    field "serial" {
      value = "source('serial')"
    }

    field "manufacturer" {
      value = "source('manufacturer')"
    }

    field "description" {
      value = "source('description')"
    }

    field "status" {
      value = "source('status')"
    }
  }

  module {
    source_items = "[m for m in (source('modules') or []) if m.get('profile') == 'Line card']"
    profile      = "Line card"
    enabled_if   = "collector.sync_modules"
    dedupe_by    = "source('serial') or source('bay_name')"

    field "bay_name" {
      value = "source('bay_name')"
    }

    field "position" {
      value = "source('position')"
    }

    field "model" {
      value = "source('model')"
    }

    field "serial" {
      value = "source('serial')"
    }

    field "manufacturer" {
      value = "source('manufacturer')"
    }

    field "description" {
      value = "source('description')"
    }

    field "status" {
      value = "source('status')"
    }
  }

  module {
    source_items = "[m for m in (source('modules') or []) if m.get('profile') == 'Module']"
    profile      = "Module"
    enabled_if   = "collector.sync_modules"
    dedupe_by    = "source('serial') or source('bay_name')"

    field "bay_name" {
      value = "source('bay_name')"
    }

    field "position" {
      value = "source('position')"
    }

    field "model" {
      value = "source('model')"
    }

    field "serial" {
      value = "source('serial')"
    }

    field "manufacturer" {
      value = "source('manufacturer')"
    }

    field "description" {
      value = "source('description')"
    }

    field "status" {
      value = "source('status')"
    }
  }
}
