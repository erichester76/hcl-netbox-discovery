# Salt master grains discovery -> NetBox collector mapping
#
# Preferred mode polls a Salt master through Salt NetAPI and normalises one
# `hosts` collection with nested interfaces and IP addresses.
#
# Required environment variables:
#   SALT_MASTER_URL      Salt NetAPI base URL, e.g. https://salt.example.com:8000
#   SALT_USER            Salt API username
#   SALT_PASS            Salt API password
#   NETBOX_URL           NetBox base URL
#   NETBOX_TOKEN         NetBox API token
#
# Optional:
#   SALT_TARGET          Target expression (default: *)
#   SALT_EXPR_FORM       Target expression form, e.g. compound
#   SALT_EAUTH           External auth backend (default: pam)
#   SALT_ARTIFACT_PATH   Fallback artifact path when mode = artifact
#   DRY_RUN              true | false (default: false)

source "salt" {
  api_type   = "salt"
  url        = "env('SALT_MASTER_URL')"
  username   = "env('SALT_USER')"
  password   = "env('SALT_PASS')"
  mode       = "master"
  target     = "env('SALT_TARGET', '*')"
  expr_form  = "env('SALT_EXPR_FORM', '')"
  eauth      = "env('SALT_EAUTH', 'pam')"

  # Fallback artifact mode:
  # mode          = "artifact"
  # artifact_path = "env('SALT_ARTIFACT_PATH')"
}

netbox {
  url   = "env('NETBOX_URL')"
  token = "env('NETBOX_TOKEN')"
}

collector {
  max_workers = 4
  dry_run     = "env('DRY_RUN', 'false')"
  sync_tag    = "salt-sync"
}

object "device" {
  source_collection = "hosts"
  netbox_resource   = "dcim.devices"
  lookup_by         = ["name"]

  prerequisite "manufacturer" {
    method   = "ensure_manufacturer"
    args     = { name = "coalesce(source('manufacturer'), 'Generic')" }
    optional = true
  }

  prerequisite "device_type" {
    method   = "ensure_device_type"
    args     = {
      model        = "coalesce(source('model'), 'Unknown')"
      manufacturer = "prereq('manufacturer')"
    }
    optional = false
  }

  prerequisite "role" {
    method   = "ensure_device_role"
    args     = { name = "'Server'" }
    optional = false
  }

  prerequisite "site" {
    method   = "ensure_site"
    args     = { name = "'salt-discovered'" }
    optional = false
  }

  field "name" {
    value = "source('name')"
  }

  field "device_type" {
    value = "prereq('device_type')"
  }

  field "role" {
    value = "prereq('role')"
  }

  field "site" {
    value = "prereq('site')"
  }

  field "serial" {
    value = "source('serial')"
  }

  field "status" {
    value = "source('status')"
  }

  field "tags" {
    value = "['salt-managed']"
  }

  field "comments" {
    value = "coalesce(source('fqdn'), source('hostname'))"
  }

  interface {
    source_items = "interfaces"

    field "name" {
      value = "source('name')"
    }

    field "type" {
      value = "coalesce(source('type'), 'other')"
    }

    field "enabled" {
      value = "source('enabled')"
    }

    field "mac_address" {
      value = "when(source('mac_address') != '', source('mac_address'), None)"
    }

    ip_address {
      source_items = "ip_addresses"

      field "address" {
        value = "source('address')"
      }

      field "status" {
        value = "source('status')"
      }
    }
  }
}
