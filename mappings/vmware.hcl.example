# VMware vCenter → NetBox collector mapping
#
# Required environment variables:
#   VCENTER_URL       vCenter hostname or IP (no https://)
#   VCENTER_USER      vCenter username
#   VCENTER_PASS      vCenter password
#   NETBOX_URL        NetBox base URL
#   NETBOX_TOKEN      NetBox API token
#
# Optional:
#   NETBOX_CACHE_BACKEND  Cache backend: none | redis | sqlite  (default: none)
#   NETBOX_CACHE_URL      Redis URL or SQLite path
#   COLLECTOR_SKIP_LINK_LOCAL_IPS  true | false  (default: false)
#   DRY_RUN               Set to "true" to log payloads without writing
#
# Multiple vCenter support:
#   To collect from more than one vCenter, set VCENTER_URL to a comma-delimited
#   list and set source.max_workers to control how many vCenter passes may run
#   in parallel. Shared VCENTER_USER and VCENTER_PASS values stay in the same
#   source block and are reused for each parsed URL.
#   Example:
#
#     source "vmware" {
#       api_type    = "vmware"
#       url         = "env('VCENTER_URL')"  # vc1.example.com,vc2.example.com,vc3.example.com
#       username    = "env('VCENTER_USER')"
#       password    = "env('VCENTER_PASS')"
#       max_workers = 2
#     }

source "vmware" {
  api_type    = "vmware"
  url         = "env('VCENTER_URL')"
  username    = "env('VCENTER_USER')"
  password    = "env('VCENTER_PASS')"
  max_workers = 1
  verify_ssl = false
}

netbox {
  url        = "env('NETBOX_URL')"
  token      = "env('NETBOX_TOKEN')"
  cache      = "env('NETBOX_CACHE_BACKEND', 'none')"
  cache_url  = "env('NETBOX_CACHE_URL', '')"
  rate_limit = "env('NETBOX_RATE_LIMIT', '0')"
}

collector {
  max_workers      = 8
  dry_run          = "env('DRY_RUN', 'false')"
  sync_tag         = "vmware-sync"
  regex_dir        = "./regex"
  sync_interfaces  = true
  sync_vms         = true
  skip_link_local_ips = "env('COLLECTOR_SKIP_LINK_LOCAL_IPS', 'false')"

}

# ---------------------------------------------------------------------------
# Clusters
# ---------------------------------------------------------------------------

object "cluster" {
  source_collection = "clusters"
  netbox_resource   = "virtualization.clusters"
  lookup_by         = ["name"]

  prerequisite "cluster_type" {
    method   = "ensure_cluster_type"
    args     = { name = "'VMWare'" }
    optional = false
  }

  prerequisite "cluster_group" {
    method   = "ensure_cluster_group"
    args     = { name = "coalesce(source('parent.parent.name'), 'Unknown')" }
    optional = true
  }

  prerequisite "site" {
    method   = "ensure_site"
    args     = { name = "regex_file(source('name'), 'cluster_to_site')" }
    optional = true
  }

  field "name" {
    value = "source('name')"
  }

  field "type" {
    value = "prereq('cluster_type')"
  }

  field "group" {
    value = "prereq('cluster_group')"
  }

  field "site" {
    value = "prereq('site')"
  }
}

# ---------------------------------------------------------------------------
# Hypervisor Hosts
# ---------------------------------------------------------------------------

object "host" {
  source_collection = "hosts"
  netbox_resource   = "dcim.devices"
  lookup_by         = ["name"]
  max_workers       = 8

  prerequisite "manufacturer" {
    method   = "ensure_manufacturer"
    args     = { name = "source('hardware.systemInfo.vendor')" }
    optional = false
  }

  prerequisite "device_type" {
    method   = "ensure_device_type"
    args     = {
      model        = "source('hardware.systemInfo.model')"
      manufacturer = "prereq('manufacturer')"
    }
    optional = false
  }

  prerequisite "role" {
    method   = "ensure_device_role"
    args     = { name = "'Hypervisor Host'" }
    optional = false
  }

  prerequisite "site" {
    method   = "ensure_site"
    args     = { name = "regex_file(source('parent.name'), 'cluster_to_site')" }
    optional = false
  }

  prerequisite "cluster_type" {
    method   = "ensure_cluster_type"
    args     = { name = "'VMWare'" }
    optional = false
  }

  prerequisite "cluster" {
    method   = "ensure_cluster"
    args     = {
      name = "source('parent.name')"
      type = "prereq('cluster_type')"
      site = "prereq('site')"
    }
    optional = false
  }

  prerequisite "platform" {
    method   = "ensure_platform"
    args     = {
       name              = "source('config.product.fullName') or 'Unknown'"
    }
    optional = true
  }

  field "name" {
    value = "replace(source('name'), '.clemson.edu', '')"
  }

  field "device_type" {
    value = "prereq('device_type')"
  }

  field "role" {
    value = "prereq('role')"
  }

  field "site" {
    value = "prereq('site')"
  }

  field "cluster" {
    value = "prereq('cluster')"
  }

  field "platform" {
    value = "prereq('platform')"
  }

  field "status" {
    value = "when(source('runtime.connectionState') == 'connected', 'active', 'offline')"
  }

  field "serial" {
    value = "source('summary.hardware.otherIdentifyingInfo[SerialNumberTag].identifierValue')"
  }

  field "tags" {
    type  = "tags"
    value = "['vmware-sync']"
  }

  # Physical NICs
  interface {
    source_items = "[{'_nic': nic, '_host_name': source('name')} for nic in (source('config.network.pnic') or [])]"
    enabled_if   = "collector.sync_interfaces"

    field "name" {
      value = "source('_nic.device')"
    }

    field "mac_address" {
      value = "upper(source('_nic.mac'))"
    }

    field "type" {
      value = "map_value(source('_nic.linkSpeed.speedMb'), {1000: '1000base-t', 10000: '10gbase-x-sfpp', 25000: '25gbase-x-sfp28', 40000: '40gbase-x-qsfpp', 100000: '100gbase-x-qsfp28'}, '1000base-t')"
    }

    field "speed" {
      value = "source('_nic.linkSpeed.speedMb')"
    }

    field "duplex" {
      value = "map_value(source('_nic.linkSpeed.duplex'), {True: 'full', False: 'half'}, None)"
    }

    field "description" {
      value = "join(' ', [source('_host_name'), source('_nic.device')])"
    }
  }

  # Management / VMkernel vNICs
  interface {
    source_items = "[{'_vnic': nic, '_host_name': replace(source('name'), '.clemson.edu', '')} for nic in (source('_enriched_vnics') or [])]"
    enabled_if   = "collector.sync_interfaces"

    field "name" {
      value = "source('_vnic.device')"
    }

    field "mac_address" {
      value = "upper(source('_vnic.spec.mac'))"
    }

    field "type" {
      value = "'virtual'"
    }

    field "description" {
      value = "join(' ', [source('_host_name'), source('_vnic.device')])"
    }

    ip_address {
      source_items = "_vnic.spec.ip"
      primary_if   = "first"

      field "address" {
        value = "join('/', [source('ipAddress'), str(mask_to_prefix(source('subnetMask')))])"
      }

      field "status" {
        value = "'active'"
      }
    }

    tagged_vlan {
      source_items = "_vnic._vlans"

      field "vid" {
        value = "source('id')"
      }

      field "name" {
        value = "source('name')"
      }

      field "site" {
        value = "prereq('site')"
      }
    }
  }
}

# ---------------------------------------------------------------------------
# Virtual Machines
# ---------------------------------------------------------------------------

object "vm" {
  source_collection = "vms"
  netbox_resource   = "virtualization.virtual_machines"
  lookup_by         = ["name", "cluster"]
  max_workers       = 8

  prerequisite "cluster" {
    method   = "ensure_cluster"
    args     = { name = "source('runtime.host.parent.name')" }
    optional = false
  }

  prerequisite "platform" {
    method   = "ensure_platform"
    args     = { name = "source('guest.guestFullName') or 'Unknown'" }
    optional = true
  }

  field "name" {
    value = "truncate(replace(source('name'), '.clemson.edu', ''), 64)"
  }

  field "cluster" {
    value = "prereq('cluster')"
  }

  field "status" {
    value = "when(source('runtime.powerState') == 'poweredOn', 'active', 'offline')"
  }

  field "vcpus" {
    value = "source('config.hardware.numCPU')"
  }

  field "memory" {
    value = "source('config.hardware.memoryMB')"
  }

  field "tags" {
    type  = "tags"
    value = "['vmware-sync']"
  }

  # VM Network Interfaces
  interface {
    source_items = "_enriched_net"
    enabled_if   = "collector.sync_interfaces"

    field "name" {
      value = "coalesce(source('name'), source('network'), upper(source('macAddress')))"
    }

    field "mac_address" {
      value = "upper(source('macAddress'))"
    }

    field "type" {
      value = "'virtual'"
    }

    ip_address {
      source_items = "ipConfig.ipAddress"
      primary_if   = "first"

      field "address" {
        value = "join('/', [source('ipAddress'), str(source('prefixLength'))])"
      }

      field "status" {
        value = "'active'"
      }
    }

    tagged_vlan {
      source_items = "[{**v, 'site_name': regex_file(source('runtime.host.parent.name'), 'cluster_to_site')} for v in (source('_vlans') or [])]"

      field "vid" {
        value = "source('id')"
      }

      field "name" {
        value = "source('name')"
      }

      field "site" {
        type     = "fk"
        resource = "dcim.sites"
        lookup   = { name = "source('site_name')" }
      }
    }
  }

  # Virtual Disks – filter to devices that have capacityInKB (VirtualDisk only)
  disk {
    source_items = "[d for d in (source('config.hardware.device') or []) if getattr(d, 'capacityInKB', None)]"
    enabled_if   = "collector.sync_vms"

    field "name" {
      value = "source('deviceInfo.label')"
    }

    field "size" {
      value = "to_mb(source('capacityInKB'))"
    }

    # description: "<vmdk-path> (Thin|Thick Provisioned <diskMode>)" – max 200 chars
    field "description" {
      value = "truncate(regex_replace((source('backing.fileName') or ''), r'([^/\\\\]+)-\\d{6}(\\.vmdk)$', r'\\1\\2') + ' (' + when(source('backing.thinProvisioned'), 'Thin Provisioned', 'Thick Provisioned') + ' ' + (source('backing.diskMode') or '') + ')', 200)"
    }
  }
}
